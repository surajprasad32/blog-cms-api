# ── Project ─────────────────────────────────────────────
PROJECT_NAME=Blog CMS API
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/blogcms

# ── JWT ──────────────────────────────────────────────────
# Generate SECRET_KEY with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────
# JSON array of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Docker Compose (use these values when running via docker-compose up) ──────
# DATABASE_URL=postgresql://bloguser:blogpass@db:5432/blogcms